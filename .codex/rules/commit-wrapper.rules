# The wrapper validates repository state before creating a local Git commit.
# Keep this allowlist narrow: it applies only to the commit wrapper.
prefix_rule(
  pattern = [
    [
      ".agents/skills/commit/scripts/validate-and-commit.sh",
      "/home/dev/.agents/skills/commit/scripts/validate-and-commit.sh",
    ],
  ],
  decision = "allow",
  justification = "Allow the reviewed local commit validation wrapper to create commits.",
  match = [
    ".agents/skills/commit/scripts/validate-and-commit.sh",
    "/home/dev/.agents/skills/commit/scripts/validate-and-commit.sh",
  ],
  not_match = [
    "/workspace/github.com/yanyi/dotfiles/.agents/skills/commit/scripts/other-script.sh",
  ],
)
